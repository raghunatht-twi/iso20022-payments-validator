<?xml version="1.0" encoding="UTF-8"?>
<!--
  INTENTIONAL FAILURES — for demonstrating the validator failure report.

  Error 1  PmtMtd = 'EXPRESS'              → invalid enumeration (allowed: TRF, CHK, TRA)
  Error 2  DbtrAcct IBAN = 'BADIBAN123'    → IBAN pattern violation (check digits must be numeric)
  Error 3  InstdAmt Ccy = 'EUROS'          → Ccy attribute pattern violation (must be exactly 3 uppercase letters)
  Error 4  UETR 3rd group = '3f4a'         → UUID v4 violation (3rd group must start with '4')
  Error 5  ChrgBr = 'BOTH'                 → invalid enumeration (allowed: DEBT, CRED, SHAR, SLEV)
-->
<Document xmlns="urn:iso:std:iso:20022:tech:xsd:pain.001.001.13">
  <CstmrCdtTrfInitn>
    <GrpHdr>
      <MsgId>DEMO-FAIL-20260601-006</MsgId>
      <CreDtTm>2026-06-01T12:00:00</CreDtTm>
      <NbOfTxs>2</NbOfTxs>
      <CtrlSum>7500.00</CtrlSum>
      <InitgPty>
        <Nm>Demo Corp</Nm>
      </InitgPty>
    </GrpHdr>

    <PmtInf>
      <PmtInfId>PMTINF-DEMO-FAIL-001</PmtInfId>
      <PmtMtd>EXPRESS</PmtMtd>                         <!-- Error 1: not a valid PaymentMethod3Code -->
      <NbOfTxs>2</NbOfTxs>
      <CtrlSum>7500.00</CtrlSum>
      <ReqdExctnDt>
        <Dt>2026-06-03</Dt>
      </ReqdExctnDt>
      <Dbtr>
        <Nm>Demo Corp</Nm>
      </Dbtr>
      <DbtrAcct>
        <Id>
          <IBAN>BADIBAN123</IBAN>                       <!-- Error 2: 'DI' at positions 3-4 must be digits -->
        </Id>
      </DbtrAcct>
      <DbtrAgt>
        <FinInstnId>
          <BICFI>DEUTDEDB</BICFI>
        </FinInstnId>
      </DbtrAgt>

      <!-- Transaction 1: wrong Ccy attribute and invalid UETR -->
      <CdtTrfTxInf>
        <PmtId>
          <EndToEndId>E2E-DEMO-FAIL-001</EndToEndId>
          <UETR>bb33cc44-ee55-3f4a-9b2c-dd77ee88ff99</UETR>  <!-- Error 4: 3rd group '3f4a' must start with '4' -->
        </PmtId>
        <Amt>
          <InstdAmt Ccy="EUROS">5000.00</InstdAmt>      <!-- Error 3: 'EUROS' is 5 chars; must be exactly 3 -->
        </Amt>
        <CdtrAgt>
          <FinInstnId>
            <BICFI>COBADEFFXXX</BICFI>
          </FinInstnId>
        </CdtrAgt>
        <Cdtr>
          <Nm>Creditor One SA</Nm>
        </Cdtr>
        <CdtrAcct>
          <Id>
            <IBAN>DE75512108001245126199</IBAN>
          </Id>
        </CdtrAcct>
        <RmtInf>
          <Ustrd>Invoice DEMO-2026-001</Ustrd>
        </RmtInf>
      </CdtTrfTxInf>

      <!-- Transaction 2: invalid charge bearer code -->
      <CdtTrfTxInf>
        <PmtId>
          <EndToEndId>E2E-DEMO-FAIL-002</EndToEndId>
        </PmtId>
        <Amt>
          <InstdAmt Ccy="EUR">2500.00</InstdAmt>
        </Amt>
        <ChrgBr>BOTH</ChrgBr>                           <!-- Error 5: not a valid ChargeBearerType1Code -->
        <CdtrAgt>
          <FinInstnId>
            <BICFI>NWBKGB2L</BICFI>
          </FinInstnId>
        </CdtrAgt>
        <Cdtr>
          <Nm>Creditor Two Ltd</Nm>
        </Cdtr>
        <CdtrAcct>
          <Id>
            <IBAN>GB29NWBK60161331926819</IBAN>
          </Id>
        </CdtrAcct>
        <RmtInf>
          <Ustrd>Invoice DEMO-2026-002</Ustrd>
        </RmtInf>
      </CdtTrfTxInf>
    </PmtInf>

  </CstmrCdtTrfInitn>
</Document>
